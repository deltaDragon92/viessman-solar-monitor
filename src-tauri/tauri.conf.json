{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Viessmann Solar Monitor",
  "version": "0.1.0",
  "identifier": "com.andreapiccini.viessmannsolarmonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Viessmann Solar Monitor",
        "width": 1360,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
